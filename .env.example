# =======================================================================
# MO Trading — Backend environment variables
# =======================================================================
# Set these on Railway (Settings → Variables) for production and in a
# local .env / shell export for development. Never commit real values.
# -----------------------------------------------------------------------

# Database (Neon Postgres)
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Cloudflare R2 — trade chart images + EOD snapshots
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=trading-journal-images
R2_PUBLIC_URL=https://<public-pull-zone>.r2.dev

# Interactive Brokers Flex Query — for /api/trades/import
# Generate at https://www.interactivebrokers.com/sso/Login → Settings →
# Account Settings → Flex Web Service. The query ID identifies which
# Trade Confirmations report to pull.
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# Anthropic API — only if/when Claude-powered features are enabled
# ANTHROPIC_API_KEY=
